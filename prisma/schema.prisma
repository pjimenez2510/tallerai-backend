// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// ENUMS
// ==========================================

enum UserRole {
  admin
  jefe_taller
  recepcionista
  mecanico
}

// ==========================================
// SISTEMA / AUTENTICACION
// ==========================================

model Tenant {
  id         String   @id @default(uuid())
  name       String   @db.VarChar(200)
  ruc        String   @unique @db.VarChar(13)
  address    String?  @db.VarChar(500)
  phone      String?  @db.VarChar(20)
  email      String?  @db.VarChar(200)
  logo_url   String?  @db.VarChar(1000)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  users    User[]
  clients  Client[]
  vehicles Vehicle[]
  products Product[]

  @@map("tenants")
}

model User {
  id            String   @id @default(uuid())
  tenant_id     String
  name          String   @db.VarChar(200)
  email         String   @db.VarChar(200)
  password_hash String   @db.VarChar(255)
  role          UserRole @default(mecanico)
  phone         String?  @db.VarChar(20)
  avatar_url    String?  @db.VarChar(1000)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  // Relations
  tenant         Tenant         @relation(fields: [tenant_id], references: [id])
  refresh_tokens RefreshToken[]

  @@unique([tenant_id, email])
  @@index([tenant_id, role])
  @@index([tenant_id, is_active])
  @@map("users")
}

// ==========================================
// CLIENTES Y VEHICULOS
// ==========================================

enum DocumentType {
  cedula
  ruc
  pasaporte
}

model Client {
  id              String       @id @default(uuid())
  tenant_id       String
  document_type   DocumentType @default(cedula)
  document_number String       @db.VarChar(20)
  name            String       @db.VarChar(200)
  email           String?      @db.VarChar(200)
  phone           String?      @db.VarChar(20)
  phone_secondary String?      @db.VarChar(20)
  address         String?      @db.VarChar(500)
  notes           String?      @db.VarChar(2000)
  is_active       Boolean      @default(true)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt

  // Relations
  tenant   Tenant    @relation(fields: [tenant_id], references: [id])
  vehicles Vehicle[]

  @@unique([tenant_id, document_number])
  @@index([tenant_id, is_active])
  @@index([tenant_id, name])
  @@map("clients")
}

model Vehicle {
  id           String   @id @default(uuid())
  tenant_id    String
  client_id    String
  plate        String   @db.VarChar(10)
  brand        String   @db.VarChar(100)
  model        String   @db.VarChar(100)
  year         Int
  color        String?  @db.VarChar(50)
  vin          String?  @db.VarChar(17)
  engine       String?  @db.VarChar(100)
  transmission String?  @db.VarChar(50)
  fuel_type    String?  @db.VarChar(30)
  mileage      Int      @default(0)
  notes        String?  @db.VarChar(2000)
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  // Relations
  tenant Tenant @relation(fields: [tenant_id], references: [id])
  client Client @relation(fields: [client_id], references: [id])

  @@unique([tenant_id, plate])
  @@index([tenant_id, client_id])
  @@index([tenant_id, is_active])
  @@index([tenant_id, plate])
  @@map("vehicles")
}

// ==========================================
// INVENTARIO Y REPUESTOS
// ==========================================

model Product {
  id             String   @id @default(uuid())
  tenant_id      String
  code           String   @db.VarChar(50)
  oem_code       String?  @db.VarChar(100)
  name           String   @db.VarChar(200)
  description    String?  @db.VarChar(2000)
  brand          String?  @db.VarChar(100)
  category       String?  @db.VarChar(100)
  unit           String   @default("unidad") @db.VarChar(30)
  cost_price     Decimal  @default(0) @db.Decimal(12, 2)
  sale_price     Decimal  @default(0) @db.Decimal(12, 2)
  stock          Int      @default(0)
  min_stock      Int      @default(0)
  location       String?  @db.VarChar(100)
  supplier       String?  @db.VarChar(200)
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  // Relations
  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@unique([tenant_id, code])
  @@index([tenant_id, is_active])
  @@index([tenant_id, name])
  @@index([tenant_id, category])
  @@map("products")
}

model RefreshToken {
  id         String   @id @default(uuid())
  user_id    String
  token_hash String   @db.VarChar(255)
  is_revoked Boolean  @default(false)
  expires_at DateTime
  created_at DateTime @default(now())

  // Relations
  user User @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([token_hash])
  @@map("refresh_tokens")
}
