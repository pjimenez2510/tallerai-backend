// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// ENUMS
// ==========================================

enum WorkOrderStatus {
  recepcion
  diagnostico
  aprobado
  en_progreso
  completado
  entregado
  cancelado
}

enum WorkOrderPriority {
  baja
  normal
  alta
  urgente
}

// ==========================================
// SISTEMA / AUTENTICACION
// ==========================================

model Tenant {
  id         String   @id @default(uuid())
  name       String   @db.VarChar(200)
  ruc        String   @unique @db.VarChar(13)
  address    String?  @db.VarChar(500)
  phone      String?  @db.VarChar(20)
  email      String?  @db.VarChar(200)
  logo_url   String?  @db.VarChar(1000)
  settings   Json?    @default("{}")
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  users           User[]
  clients         Client[]
  vehicles        Vehicle[]
  products        Product[]
  work_orders     WorkOrder[]
  services        Service[]
  purchase_orders PurchaseOrder[]
  notifications   Notification[]
  roles           Role[]

  @@map("tenants")
}

model Role {
  id          String   @id @default(uuid())
  tenant_id   String
  name        String   @db.VarChar(100)
  slug        String   @db.VarChar(50)
  description String?  @db.VarChar(500)
  permissions String[] @default([])
  is_system   Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id])
  users  User[]

  @@unique([tenant_id, slug])
  @@index([tenant_id])
  @@map("roles")
}

model User {
  id            String   @id @default(uuid())
  tenant_id     String
  name          String   @db.VarChar(200)
  email         String   @db.VarChar(200)
  password_hash String   @db.VarChar(255)
  role_id       String
  phone         String?  @db.VarChar(20)
  avatar_url    String?  @db.VarChar(1000)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  // Relations
  tenant               Tenant         @relation(fields: [tenant_id], references: [id])
  role                 Role           @relation(fields: [role_id], references: [id])
  refresh_tokens       RefreshToken[]
  assigned_work_orders WorkOrder[]    @relation("assigned_mechanic")
  notifications        Notification[]

  @@unique([tenant_id, email])
  @@index([tenant_id, is_active])
  @@index([tenant_id, role_id])
  @@map("users")
}

// ==========================================
// CLIENTES Y VEHICULOS
// ==========================================

enum DocumentType {
  cedula
  ruc
  pasaporte
}

model Client {
  id              String       @id @default(uuid())
  tenant_id       String
  document_type   DocumentType @default(cedula)
  document_number String       @db.VarChar(20)
  name            String       @db.VarChar(200)
  email           String?      @db.VarChar(200)
  phone           String?      @db.VarChar(20)
  phone_secondary String?      @db.VarChar(20)
  address         String?      @db.VarChar(500)
  notes           String?      @db.VarChar(2000)
  is_active       Boolean      @default(true)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt

  // Relations
  tenant      Tenant      @relation(fields: [tenant_id], references: [id])
  vehicles    Vehicle[]
  work_orders WorkOrder[]

  @@unique([tenant_id, document_number])
  @@index([tenant_id, is_active])
  @@index([tenant_id, name])
  @@map("clients")
}

model Vehicle {
  id           String   @id @default(uuid())
  tenant_id    String
  client_id    String
  plate        String   @db.VarChar(10)
  brand        String   @db.VarChar(100)
  model        String   @db.VarChar(100)
  year         Int
  color        String?  @db.VarChar(50)
  vin          String?  @db.VarChar(17)
  engine       String?  @db.VarChar(100)
  transmission String?  @db.VarChar(50)
  fuel_type    String?  @db.VarChar(30)
  mileage      Int      @default(0)
  notes        String?  @db.VarChar(2000)
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  // Relations
  tenant      Tenant      @relation(fields: [tenant_id], references: [id])
  client      Client      @relation(fields: [client_id], references: [id])
  work_orders WorkOrder[]

  @@unique([tenant_id, plate])
  @@index([tenant_id, client_id])
  @@index([tenant_id, is_active])
  @@index([tenant_id, plate])
  @@map("vehicles")
}

// ==========================================
// INVENTARIO Y REPUESTOS
// ==========================================

model Product {
  id             String   @id @default(uuid())
  tenant_id      String
  code           String   @db.VarChar(50)
  oem_code       String?  @db.VarChar(100)
  name           String   @db.VarChar(200)
  description    String?  @db.VarChar(2000)
  brand          String?  @db.VarChar(100)
  category       String?  @db.VarChar(100)
  unit           String   @default("unidad") @db.VarChar(30)
  cost_price     Decimal  @default(0) @db.Decimal(12, 2)
  sale_price     Decimal  @default(0) @db.Decimal(12, 2)
  stock          Int      @default(0)
  min_stock      Int      @default(0)
  location       String?  @db.VarChar(100)
  supplier       String?  @db.VarChar(200)
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  // Relations
  tenant               Tenant              @relation(fields: [tenant_id], references: [id])
  stock_movements      StockMovement[]
  work_order_parts     WorkOrderPart[]
  purchase_order_items PurchaseOrderItem[]

  @@unique([tenant_id, code])
  @@index([tenant_id, is_active])
  @@index([tenant_id, name])
  @@index([tenant_id, category])
  @@map("products")
}

enum StockMovementType {
  ingreso
  salida
  ajuste
}

model StockMovement {
  id             String            @id @default(uuid())
  tenant_id      String
  product_id     String
  type           StockMovementType
  quantity       Int
  previous_stock Int
  new_stock      Int
  unit_cost      Decimal?          @db.Decimal(12, 2)
  reference      String?           @db.VarChar(200)
  notes          String?           @db.VarChar(500)
  created_by     String?
  created_at     DateTime          @default(now())

  // Relations
  product Product @relation(fields: [product_id], references: [id])

  @@index([tenant_id, product_id])
  @@index([tenant_id, created_at])
  @@map("stock_movements")
}

model Service {
  id          String  @id @default(uuid())
  tenant_id   String
  code        String  @db.VarChar(50)
  name        String  @db.VarChar(200)
  description String? @db.VarChar(2000)
  price       Decimal @default(0) @db.Decimal(12, 2)
  is_active   Boolean @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@unique([tenant_id, code])
  @@index([tenant_id, is_active])
  @@map("services")
}

// ==========================================
// ORDENES DE TRABAJO
// ==========================================

model WorkOrder {
  id               String            @id @default(uuid())
  tenant_id        String
  order_number     String            @db.VarChar(30)
  client_id        String
  vehicle_id       String
  assigned_to      String?
  parent_id        String?
  status           WorkOrderStatus   @default(recepcion)
  priority         WorkOrderPriority @default(normal)
  description      String            @db.VarChar(5000)
  diagnosis        String?           @db.VarChar(5000)
  internal_notes   String?           @db.VarChar(5000)
  mileage_in       Int?
  estimated_date   DateTime?
  completed_date   DateTime?
  delivered_date   DateTime?
  total_parts      Decimal           @default(0) @db.Decimal(12, 2)
  total_labor      Decimal           @default(0) @db.Decimal(12, 2)
  total            Decimal           @default(0) @db.Decimal(12, 2)
  client_signature String?           @db.Text
  signature_date   DateTime?
  damage_map       Json?
  damage_notes     String?           @db.VarChar(2000)
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt

  // Relations
  tenant      Tenant                  @relation(fields: [tenant_id], references: [id])
  client      Client                  @relation(fields: [client_id], references: [id])
  vehicle     Vehicle                 @relation(fields: [vehicle_id], references: [id])
  mechanic    User?                   @relation("assigned_mechanic", fields: [assigned_to], references: [id])
  parent      WorkOrder?              @relation("supplements", fields: [parent_id], references: [id])
  supplements WorkOrder[]             @relation("supplements")
  tasks       WorkOrderTask[]
  parts       WorkOrderPart[]
  attachments WorkOrderAttachment[]

  @@unique([tenant_id, order_number])
  @@index([tenant_id, status])
  @@index([tenant_id, client_id])
  @@index([tenant_id, vehicle_id])
  @@index([tenant_id, assigned_to])
  @@index([tenant_id, created_at])
  @@index([tenant_id, parent_id])
  @@map("work_orders")
}

model WorkOrderTask {
  id            String  @id @default(uuid())
  work_order_id String
  description   String  @db.VarChar(500)
  is_completed  Boolean @default(false)
  labor_hours   Decimal @default(0) @db.Decimal(6, 2)
  labor_cost    Decimal @default(0) @db.Decimal(12, 2)
  sort_order    Int     @default(0)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  // Relations
  work_order WorkOrder @relation(fields: [work_order_id], references: [id], onDelete: Cascade)

  @@index([work_order_id])
  @@map("work_order_tasks")
}

model WorkOrderPart {
  id            String  @id @default(uuid())
  work_order_id String
  product_id    String
  quantity      Int     @default(1)
  unit_price    Decimal @db.Decimal(12, 2)
  total         Decimal @db.Decimal(12, 2)
  created_at    DateTime @default(now())

  // Relations
  work_order WorkOrder @relation(fields: [work_order_id], references: [id], onDelete: Cascade)
  product    Product   @relation(fields: [product_id], references: [id])

  @@index([work_order_id])
  @@index([product_id])
  @@map("work_order_parts")
}

// ==========================================
// COMPRAS
// ==========================================

model PurchaseOrder {
  id           String    @id @default(uuid())
  tenant_id    String
  order_number String    @db.VarChar(20)
  supplier     String    @db.VarChar(200)
  notes        String?   @db.VarChar(2000)
  total        Decimal   @default(0) @db.Decimal(12, 2)
  status       String    @default("pendiente") @db.VarChar(20)
  received_at  DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  tenant Tenant              @relation(fields: [tenant_id], references: [id])
  items  PurchaseOrderItem[]

  @@unique([tenant_id, order_number])
  @@index([tenant_id, status])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id                String  @id @default(uuid())
  purchase_order_id String
  product_id        String
  quantity          Int
  unit_cost         Decimal @db.Decimal(12, 2)
  total             Decimal @db.Decimal(12, 2)

  purchase_order PurchaseOrder @relation(fields: [purchase_order_id], references: [id], onDelete: Cascade)
  product        Product       @relation(fields: [product_id], references: [id])

  @@index([purchase_order_id])
  @@map("purchase_order_items")
}

model WorkOrderAttachment {
  id            String   @id @default(uuid())
  work_order_id String
  filename      String   @db.VarChar(255)
  mime_type     String   @db.VarChar(100)
  size          Int
  data          String   @db.Text
  description   String?  @db.VarChar(500)
  uploaded_by   String?
  created_at    DateTime @default(now())

  work_order WorkOrder @relation(fields: [work_order_id], references: [id], onDelete: Cascade)

  @@index([work_order_id])
  @@map("work_order_attachments")
}

model RefreshToken {
  id         String   @id @default(uuid())
  user_id    String
  token_hash String   @db.VarChar(255)
  is_revoked Boolean  @default(false)
  expires_at DateTime
  created_at DateTime @default(now())

  // Relations
  user User @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([token_hash])
  @@map("refresh_tokens")
}

model Notification {
  id         String   @id @default(uuid())
  tenant_id  String
  user_id    String
  type       String   @db.VarChar(50)
  title      String   @db.VarChar(200)
  message    String   @db.VarChar(500)
  is_read    Boolean  @default(false)
  metadata   Json?
  created_at DateTime @default(now())

  // Relations
  tenant Tenant @relation(fields: [tenant_id], references: [id])
  user   User   @relation(fields: [user_id], references: [id])

  @@index([tenant_id, user_id, is_read])
  @@index([tenant_id, user_id, created_at])
  @@map("notifications")
}
